# Hermes Agent — OpenShell sandbox image for retail demo
# Based on official nousresearch/hermes-agent (dashboard + TUI pre-built)
# Pattern from NemoClaw PR #4442: HERMES_TUI_DIR, socat bridge, --skip-build
# Secret (OPENAI_API_KEY) injected at deploy time via .env upload

FROM docker.io/nousresearch/hermes-agent:v2026.6.5

USER root

RUN apt-get update -qq && apt-get install -y -qq tar iproute2 socat 2>/dev/null || true

RUN groupadd -g 1001 sandbox 2>/dev/null || true && \
    useradd -m -u 1001 -g sandbox -s /bin/bash -d /sandbox sandbox 2>/dev/null || true

RUN install -d -o sandbox -g sandbox /workspace /sandbox /sandbox/.hermes

RUN chmod -R a+rX /opt/hermes && \
    ln -sf /opt/hermes/.venv/bin/hermes /usr/local/bin/hermes

# Patch: normalize 0.0.0.0/:: to 127.0.0.1 in TUI WebSocket URLs.
# When the dashboard binds 0.0.0.0 for gated/OAuth mode, the TUI child would
# connect to ws://0.0.0.0:port which SSRF protection blocks. The TUI runs on
# the same host, so 127.0.0.1 is correct. Upstream PR candidate.
# We also add a patch to auto-discover MCP tools at dashboard startup.
COPY examples/retail/deploy/patches/fix-tui-wildcard-bind.py /tmp/fix-tui-wildcard-bind.py
RUN python3 /tmp/fix-tui-wildcard-bind.py \
      /opt/hermes/hermes_cli/web_server.py \
      /opt/hermes/tools/mcp_tool.py && \
    rm /tmp/fix-tui-wildcard-bind.py

# Bake non-secret config
COPY examples/retail/deploy/hermes-config/config.yaml /sandbox/.hermes/config.yaml
COPY examples/retail/deploy/hermes-config/active_profile /sandbox/.hermes/active_profile
COPY examples/retail/deploy/hermes-config/profiles/ /sandbox/.hermes/profiles/

# Dashboard theme — must be in each profile's dashboard-themes/ dir
COPY examples/retail/deploy/hermes-chart/files/dashboard-themes/redhat.yaml /sandbox/.hermes/dashboard-themes/redhat.yaml
RUN for p in /sandbox/.hermes/profiles/retail-*/; do \
      mkdir -p "${p}dashboard-themes" && \
      cp /sandbox/.hermes/dashboard-themes/redhat.yaml "${p}dashboard-themes/"; \
    done

RUN chown -R sandbox:sandbox /sandbox/.hermes

ENV HERMES_HOME=/sandbox/.hermes
ENV TERM=xterm-256color
ENV HERMES_TUI_DIR="/opt/hermes/ui-tui"

# Config migration at build time, then fix ownership
RUN HERMES_HOME=/sandbox/.hermes /usr/local/bin/hermes config migrate || true
RUN chown -R sandbox:sandbox /sandbox/.hermes

COPY examples/retail/deploy/hermes-start.sh /usr/local/bin/hermes-start.sh

WORKDIR /workspace

CMD ["/usr/local/bin/hermes-start.sh"]
